# Copy to ".env" in this directory so Docker Compose picks it up (optional).
# docker compose automatically loads ".env" for variable substitution.
#
# --- GUI: set DISPLAY for your OS ---
# Linux (local X11):   DISPLAY=:0
# macOS + XQuartz:     DISPLAY=host.docker.internal:0
# Headless (Xvfb):     leave DISPLAY unset or empty (entrypoint starts Xvfb :99)
#
DISPLAY=:0

# Optional: set to the same value as ./VERSION so image labels and tags match releases
# VPE_VERSION=1.2.0

# Optional: NW.js SDK version at image build time (must match package.json / NWJS_VERSION in bin/visual-page-editor)
# NWJS_VERSION=0.109.1
